---
import Layout from "../../layouts/Layout.astro";
import TrajeInmersionImg from "../../assets/traje-inmersion.png";
import LogoGeamarImg from "../../assets/logo-geamar.png";
import LogoPrimeImg from "../../assets/logo-prime-patagonia.jpg";
import LogoCo2 from "../../assets/co2.jpeg";
import LogoGcitec from "../../assets/gcitec-logo.png";
import LogoImpreLab from "../../assets/Logo-Inprelab.jpeg";

const servicios = [
  { titulo: "Cargas de Botellas CO2", link: "co2-modal", logo: LogoCo2.src },
  {
    titulo: "Consultorías Marítimas",
    link: "https://www.geamar.cl",
    external: true,
    logo: LogoGeamarImg.src,
  },
  {
    titulo: "Capacitación de Seguridad Marítima",
    link: "https://primepatagonia.cl",
    external: true,
    logo: LogoPrimeImg.src,
  },
  {
    titulo: "Equipos Certificados G-Citec",
    link: "https://g-citec.cl/",
    external: true,
    logo: LogoGcitec.src,
  },
  {
    titulo: "Equipos Calibrados InpreLab",
    link: "https://inprelab.cl/",
    external: true,
    logo: LogoImpreLab.src,
  },
];

const co2Info = {
  titulo: "Carga de Botellas CO2",
  descripcion:
    "Servicio especializado de recarga de extintores y botellas de CO2 para equipos de seguridad marítima. Cumplimos con los más altos estándares de calidad y normativas vigentes.",
  caracteristicas: [
    {
      icono: "🔋",
      titulo: "Recarga Profesional",
      descripcion:
        "Uso de CO2 de alta pureza para garantizar la efectividad del agente extintor",
    },
    {
      icono: "✓",
      titulo: "Certificación",
      descripcion: "Documentación y certificación de cada carga realizada",
    },
    {
      icono: "⚡",
      titulo: "Rápido Turno",
      descripcion: "Procesos eficientes para minimizar el tiempo de espera",
    },
    {
      icono: "📋",
      titulo: "Normativa DS 44",
      descripcion:
        "Cumplimiento total con el Decreto Supremo 44 y normativas marítimas",
    },
  ],
};

const faqs = [
  {
    pregunta: "¿Cada cuánto se revisa un traje de inmersión?",
    respuesta:
      "De acuerdo con MSC/Circ.1114, los trajes deben someterse a pruebas de presión de aire para detectar fugas ocultas cada 3 años.",
  },
  {
    pregunta: "¿Qué pruebas realizan?",
    respuesta:
      "Pruebas de inflado, buscando grietas, roturas o costuras despegadas",
  },
  {
    pregunta: "¿Qué vida útil un traje de inmersión?",
    respuesta:
      "Generalmente, los trajes tienen una vida útil de aproximadamente 10 años, tras lo cual la inspección anual podría no ser rentable.",
  },
];
---

<Layout title="Trajes de Inmersión | SIMAUSTRAL">
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Inicio</a> / <a href="/servicios">Servicios</a> / Trajes de Inmersión
      </nav>
      <h1>Mantención, Reparación y Certificación de Trajes de Inmersión</h1>
      <p class="subtitle">
        Servicios especializados para garantizar la seguridad y operatividad de
        los trajes de inmersión según normativas internacionales.
      </p>
    </div>
  </section>

  <section class="main-content">
    <div class="container">
      <div class="content-grid">
        <div class="main-column">
          <section class="hero-image">
            <img src={TrajeInmersionImg.src} alt="Trajes de inmersión" />
          </section>

          <section class="bento-grid">
            <div class="bento-card bento-highlight">
              <div class="bento-icon">🤿</div>
              <h3>Trajes de Inmersión</h3>
              <p>
                <span class="subs">
                  Mantención, reparación y certificación según normativas SOLAS
                  y MSC/Circ.1114.
                </span>
              </p>
            </div>
