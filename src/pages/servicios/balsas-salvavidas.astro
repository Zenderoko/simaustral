---
import Layout from "../../layouts/Layout.astro";
import BalsasImg from "../../assets/balsas.jpeg";
import Balsas2Img from "../../assets/balsas2.jpeg";

const servicios = [
  { titulo: "Cargas de Botellas CO2", link: "co2-modal" },
  {
    titulo: "Consultorías Marítimas",
    link: "https://www.geamar.cl",
    external: true,
  },
  {
    titulo: "Capacitación de Seguridad Marítima",
    link: "https://primepatagonia.cl",
    external: true,
  },
];

const caracteristicas = [
  {
    icono: "🔍",
    titulo: "Inspección Completa",
    desc: "Pruebas de presión, inflado y revisión de piso",
  },
  {
    icono: "🔧",
    titulo: "Mantención",
    desc: "Reemplazo de componentes y repacking",
  },
  {
    icono: "📜",
    titulo: "Certificación",
    desc: "Documentación para fiscalización",
  },
  { icono: "⚡", titulo: "Respuesta Rápida", desc: "Hasta 250 balsas/año" },
];

const faqs = [
  {
    pregunta: "¿Cada cuánto se certifica la balsa?",
    respuesta: "Una vez al año en Estaciones de Balsas autorizadas",
  },
  {
    pregunta: "¿Quién realiza la inspección?",
    respuesta:
      "Estaciones de Balsas autorizadas que cuentan con Personal habilitado por la Autoridad Marítima como Inspector de Balsas Salvavidas.",
  },
  {
    pregunta: "¿Qué pruebas realizan?",
    respuesta:
      "Dependiendo del año de fabricación, las pruebas de presión de trabajo pueden ser más exigentes. Cada 5 años se realiza la prueba de inflado con gas y la correspondiente prueba hidrostática a la botella de inflado.",
  },

  {
    pregunta: "¿Atienden yates?",
    respuesta:
      "Si, atendemos todo tipo de naves de tráfico nacional y deportivas",
  },
];
---

<Layout title="Certificación y Mantención de Balsas Salvavidas | SIMAUSTRAL">
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Home</a> / <a href="/servicios">Servicios</a> / Balsas Salvavidas
      </nav>
      <h1>Certificación y Mantención de Balsas Salvavidas</h1>
      <p class="subtitle">Servicio técnico autorizado con cumplimiento SOLAS</p>
    </div>
  </section>

  <section class="main-content">
    <div class="container">
      <div class="content-grid">
        <div class="main-column">
          <section class="hero-image">
            <img
              src={Balsas2Img.src}
              alt="Balsas Salvavidas"
            />
          </section>

          <section class="bento-grid">
            <div class="bento-card bento-highlight">
              <img src={BalsasImg.src} alt="Balsas Salvavidas" class="balsa-img" />
              <h3>Balsas Salvavidas</h3>
              <p>
                <span class="subs"
                  >Servicio técnico autorizado para inspección, reparación,
                  mantención y certificación de Balsas Salvavidas, según lo
                  establecido por el convenio SOLAS en el Código Internacional
                  de Dispositivos de Salvamento (<a
                    href="https://www.directemar.cl/directemar/site/docs/20220623/20220623152936/codigo_ids_version__cl_23_6_22_caa_rrt_actualizado_al_22_de_octubre_de_2024.pdf"
                    target="_blank"
                    style="color: #f59e0b;">Código I.D.S.</a
                  >)</span
                >
              </p>
            </div>
            <div class="bento-card">
              <div class="bento-icon">🔍</div>
              <h4>Inspección Técnica</h4>
              <p>
                Pruebas de presión, inflado con gas, costura de pisos y ensayos
                según antigüedad de la balsa.
              </p>
            </div>
            <div class="bento-card">
              <div class="bento-icon">🔧</div>
              <h4>Mantención</h4>
              <p>
                Revisión, mantención, y reparación de balsas salvavidas
                inflables, incluidas sus unidades de destrinca hidrostática y
                reemplazo de componentes críticos y elementos de supervivencia.
              </p>
            </div>
            <div class="bento-card bento-wide">
              <div class="bento-icon">📜</div>
              <h4>Certificación Oficial</h4>
              <p>
                Emisión de certificado con información del equipo de
                supervivencia y etiquetado del contenedor exigido por Autoridad
                Marítima Nacional
              </p>
            </div>
          </section>

          <!-- <section class="capacidades">
            <h2>Capacidades que te ahorran tiempo</h2>
            <div class="stats-grid">
              <div class="stat-item">
                <span class="stat-number">250+</span>
                <span class="stat-label">Balsas por año</span>
              </div>
              <div class="stat-item">
                <span class="stat-number">25</span>
                <span class="stat-label">Balsas auxiliares</span>
              </div>
              <div class="stat-item">
                <span class="stat-number">100%</span>
                <span class="stat-label">Documentación lista</span>
              </div>
            </div>
          </section>

          <section class="nota-info">
            <p>
              <strong>Nota importante:</strong> En Chile, las balsas deben ser atendidas
              por estaciones aprobadas y personal con licencias que establece Directemar
              (DGTM).
            </p>
          </section> -->

          <section class="clientes">
            <h2>Nuestros clientes</h2>
            <div class="clientes-grid">
              <div class="cliente-item">
                <span class="cliente-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path>
                    <path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"></path>
                    <path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"></path>
                    <path d="M12 10V4.5a.5.5 0 0 1 1 0V4a1 1 0 0 1 1 1v4"></path>
                  </svg>
                </span><span>Naves Mayores de Tráfico Nacional</span>
              </div>
              <div class="cliente-item">
                <span class="cliente-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 12h3"></path>
                    <path d="M6 8H4a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1"></path>
                    <path d="M8 8H6a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1"></path>
                    <path d="M10 8H8a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1"></path>
                    <path d="M12 8h-2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1"></path>
                    <path d="M14 8h-2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1"></path>
                    <path d="M16 8h-2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1"></path>
                    <path d="M18 8h-2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h1"></path>
                    <path d="M20 12h3"></path>
                    <path d="M22 12v4a2 2 0 0 1-2 2h-1"></path>
                    <path d="M2 12v4a2 2 0 0 0 2 2h1"></path>
                  </svg>
                </span><span>Naves Menores</span>
              </div>
              <div class="cliente-item">
                <span class="cliente-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="3"></circle>
                    <line x1="12" y1="22" x2="12" y2="8"></line>
                    <path d="M5 12H2a10 10 0 0 0 20 0h-3"></path>
                  </svg>
                </span><span>Artefactos Navales</span>
              </div>
              <div class="cliente-item">
                <span class="cliente-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2h2a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h2"></path>
                    <path d="M22 12h-6l-2 3h-4l-2-3H2"></path>
                    <path d="M2 12v6h20v-6"></path>
                  </svg>
                </span><span>Embarcaciones Deportivas</span>
              </div>
            </div>
          </section>

          <section class="faqs">
            <h2>Preguntas Frecuentes</h2>
            {
              faqs.map((faq) => (
                <div class="faq-item">
                  <>
                    <h3>{faq.pregunta}</h3>
                    <p>{faq.respuesta}</p>
                  </>
                </div>
              ))
            }
          </section>
        </div>

        <aside class="sidebar">
          <div class="cta-box">
            <h3>¿Necesitas cotizar?</h3><p>
              Te ayudamos con tu cotización rápidamente.
            </p><a href="/contacto" class="cta-button">Solicitar Cotización</a
            ><a
              href="https://wa.me/56979799006"
              target="_blank"
              class="whatsapp-button"
              ><svg
                class="whatsapp-icon"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path></svg
              >Contactar por WhatsApp</a
            >
          </div>
          <div class="otros-servicios">
            <h3>Otros Servicios</h3><ul>
              {
                servicios.map((s) => (
                  <li>
                    <a
                      href={s.link === "co2-modal" ? "#" : s.link}
                      class={s.link === "co2-modal" ? "open-modal" : ""}
                      target={s.external ? "_blank" : "_self"}
                      rel={s.external ? "noopener noreferrer" : ""}
                      data-modal="co2"
                    >
                      {s.titulo}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div id="co2-modal" class="modal-overlay">
    <div class="modal-content">
      <button class="modal-close">&times;</button>
      <h2 class="modal-title">🔋 Carga de Botellas CO2</h2>
      <p class="modal-description">Servicio especializado de recarga de extintores y botellas de CO2 para equipos de seguridad marítima. Cumplimos con los más altos estándares de calidad y normativas vigentes.</p>
      
      <div class="bento-grid">
        <div class="bento-card">
          <div class="bento-icon">🔋</div>
          <h4>Recarga Profesional</h4>
          <p>Uso de CO2 de alta pureza para garantizar la efectividad del agente extintor</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">✓</div>
          <h4>Certificación</h4>
          <p>Documentación y certificación de cada carga realizada</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">⚡</div>
          <h4>Rápido Turno</h4>
          <p>Procesos eficientes para minimizar el tiempo de espera</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">📋</div>
          <h4>Normativa DS 44</h4>
          <p>Cumplimiento total con el Decreto Supremo 44 y normativas marítimas</p>
        </div>
      </div>
      
      <div class="modal-cta">
        <a href="/contacto" class="cta-button">Solicitar Cotización</a>
        <a href="https://wa.me/56979799006" target="_blank" class="whatsapp-button">
          <svg class="whatsapp-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .subs {
    color: #c3c4c4;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .page-header {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 3rem 2rem;
  }
  .breadcrumbs {
    font-size: 0.875rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }
  .breadcrumbs a {
    color: #fff;
    text-decoration: underline;
  }
  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .subtitle {
    font-size: 1.125rem;
    opacity: 0.9;
    max-width: 700px;
    line-height: 1.6;
  }
  .main-content {
    padding: 3rem 0;
  }
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
  }
  .main-column section {
    margin-bottom: 3rem;
  }

  .hero-image {
    margin-bottom: 2rem;
    border-radius: 16px;
    overflow: hidden;
  }
  .hero-image img {
    width: 100%;
    height: 350px;
    object-fit: cover;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .bento-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }
  .bento-card:hover {
    border-color: #1e3a5f;
    box-shadow: 0 8px 30px rgba(30, 58, 95, 0.1);
    transform: translateY(-4px);
  }
  .bento-card.bento-highlight {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    grid-column: span 3;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .bento-card.bento-highlight h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .bento-card.bento-highlight p {
    opacity: 0.9;
  }
  .bento-card.bento-wide {
    grid-column: span 2;
  }
  .bento-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .balsa-img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 12px;
    margin-right: 1.5rem;
  }
  .bento-card h4 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .bento-card p {
    color: #6b7280;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .capacidades h2 {
    color: #1e3a5f;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .stat-item {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 2rem;
    border-radius: 16px;
    text-align: center;
  }
  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
  }
  .stat-label {
    font-size: 0.875rem;
    opacity: 0.9;
  }

  .nota-info {
    background: #fef3c7;
    border-left: 4px solid #f59e0b;
    padding: 1.25rem;
    border-radius: 8px;
  }
  .nota-info p {
    color: #92400e;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  .clientes h2 {
    color: #1e3a5f;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  .clientes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .cliente-item {
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    padding: 1.5rem;
    border-radius: 12px;
    text-align: center;
    color: #4b5563;
    font-weight: 500;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    transition: all 0.3s ease;
  }

  .cliente-item:hover {
    border-color: #1e3a5f;
    transform: translateY(-3px);
    box-shadow: 0 4px 15px rgba(30, 58, 95, 0.1);
  }

  .cliente-icon {
    width: 48px;
    height: 48px;
    color: #1e3a5f;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cliente-icon svg {
    width: 100%;
    height: 100%;
  }

  .faq-item {
    margin-bottom: 1rem;
    padding: 1.25rem;
    background: #f8fafc;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }
  .faq-item h3 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .faq-item p {
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  .sidebar {
    position: sticky;
    top: 100px;
    align-self: start;
  }
  .cta-box {
    background: #1e3a5f;
    color: #fff;
    padding: 1.5rem;
    border-radius: 16px;
    margin-bottom: 2rem;
  }
  .cta-box h3 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }
  .cta-box p {
    font-size: 0.875rem;
    opacity: 0.9;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .cta-button {
    display: block;
    background: #fff;
    color: #1e3a5f;
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }
  .cta-button:hover {
    background: #f3f4f6;
  }
  .whatsapp-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #25d366;
    color: #fff;
    padding: 0.875rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    margin-top: 1rem;
    transition: all 0.3s ease;
    animation: pulse-green 2s infinite;
  }
  .whatsapp-button:hover {
    background: #128c7e;
    transform: scale(1.02);
  }
  .whatsapp-icon {
    width: 24px;
    height: 24px;
  }
  @keyframes pulse-green {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.4);
    }
    50% {
      box-shadow: 0 0 0 12px rgba(37, 211, 102, 0);
    }
  }
  .otros-servicios {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
  }
  .otros-servicios h3 {
    color: #1e3a5f;
