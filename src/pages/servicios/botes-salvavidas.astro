---
import Layout from "../../layouts/Layout.astro";

const servicios = [
  { titulo: "Balsas Salvavidas", link: "/servicios/balsas-salvavidas" },
  { titulo: "Extintores", link: "/servicios/extintores" },
  { titulo: "EPP", link: "/servicios/epp" },
  { titulo: "Sistemas Fijos", link: "/servicios/sistemas-fijos" },
  { titulo: "Pruebas de Carga", link: "/servicios/pruebas-carga" },
  { titulo: "Prácticas Extintores", link: "/servicios/practicas-extintores" },
];

const faqs = [
  {
    pregunta: "¿Cada cuánto se certifica el bote?",
    respuesta:
      "Generalmente una vez al año, según normativas SOLAS y disposiciones de la Autoridad Marítima.",
  },
  {
    pregunta: "¿Qué pruebas realizan?",
    respuesta:
      "Inspección visual, pruebas de inflado, prueba de estabilidad y verificación de mecanismos.",
  },
  {
    pregunta: "¿Realizan reparaciones?",
    respuesta:
      "Sí, realizamos reparaciones y reemplazo de componentes dañados.",
  },
];
---

<Layout title="Mantención y Certificación de Botes Salvavidas | SIMAUSTRAL">
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Home</a> / <a href="/servicios">Servicios</a> / Botes Salvavidas
      </nav>
      <h1>Mantención y Certificación de Botes Salvavidas</h1>
      <p class="subtitle">
        Inspección, certificación y reparación de botes salvavidas según
        normativas internacionales.
      </p>
    </div>
  </section>

  <section class="main-content">
    <div class="container">
      <div class="content-grid">
        <div class="main-column">
          <section class="hero-image">
            <img
              src="https://images.pexels.com/photos/36305136/pexels-photo-36305136.jpeg"
              alt="Botes salvavidas"
            />
          </section>

          <section class="bento-grid">
            <div class="bento-card bento-highlight">
              <div class="bento-icon">🛶</div>
              <h3>Botes Salvavidas</h3>
              <p>
                <span class="subs">
                  Inspección, certificación y reparación según normativas SOLAS.
                </span>
              </p>
            </div>
            <div class="bento-card">
              <div class="bento-icon">🔍</div>
              <h4>Inspección Técnica</h4>
              <p>Evaluación de casco, estructura, flotación y accesorios.</p>
            </div>
            <div class="bento-card">
              <div class="bento-icon">⚡</div>
              <h4>Pruebas Funcionales</h4>
              <p>Inflado, estabilidad y mecanismos de lanzado.</p>
            </div>
            <div class="bento-card bento-wide">
              <div class="bento-icon">🔧</div>
              <h4>Mantención y Reparación</h4>
              <p>
                Reemplazo de componentes y reparaciones estructurales. Emisión
                de certificado y rotulado conforme.
              </p>
            </div>
          </section>

          <section class="tipos">
            <h2>Tipos de botes que atendemos</h2>
            <div class="tipos-grid">
              <div class="tipo-item">
                <span class="tipo-icon">🚤</span>
                <span>Botes rígidos</span>
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">🎈</span>
                <span>Botes inflables</span>
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">🚁</span>
                <span>Botes de emergencia</span>
              </div>
            </div>
          </section>

          <section class="faqs">
            <h2>Preguntas Frecuentes</h2>
            {
              faqs.map((faq) => (
                <div class="faq-item">
                  <>
                    <h3>{faq.pregunta}</h3>
                    <p>{faq.respuesta}</p>
                  </>
                </div>
              ))
            }
          </section>
        </div>

        <aside class="sidebar">
          <div class="cta-box">
            <h3>¿Necesitas cotizar?</h3><p>
              Te ayudamos con tu cotización rápidamente.
            </p><a href="/contacto" class="cta-button">Solicitar Cotización</a
            ><a
              href="https://wa.me/56979799006"
              target="_blank"
              class="whatsapp-button"
              ><svg
                class="whatsapp-icon"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path></svg
              >Contactar por WhatsApp</a
            >
          </div>
          <div class="otros-servicios">
            <h3>Otros Servicios</h3><ul>
              {
                servicios.map((s) => (
                  <li>
                    <a href={s.link}>{s.titulo}</a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  .subs {
    color: #c3c4c4;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .page-header {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 3rem 2rem;
  }
  .breadcrumbs {
    font-size: 0.875rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }
  .breadcrumbs a {
    color: #fff;
    text-decoration: underline;
  }
  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .subtitle {
    font-size: 1.125rem;
    opacity: 0.9;
    max-width: 700px;
    line-height: 1.6;
  }
  .main-content {
    padding: 3rem 0;
  }
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
  }
  .main-column section {
    margin-bottom: 3rem;
  }

  .hero-image {
    margin-bottom: 2rem;
    border-radius: 16px;
    overflow: hidden;
  }
  .hero-image img {
    width: 100%;
    height: 350px;
    object-fit: cover;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .bento-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }
  .bento-card:hover {
    border-color: #1e3a5f;
    box-shadow: 0 8px 30px rgba(30, 58, 95, 0.1);
    transform: translateY(-4px);
  }
  .bento-card.bento-highlight {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    grid-column: span 3;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .bento-card.bento-highlight h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .bento-card.bento-highlight p {
    opacity: 0.9;
  }
  .bento-card.bento-wide {
    grid-column: span 2;
  }
  .bento-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .bento-card h4 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .bento-card p {
    color: #6b7280;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  .tipos h2 {
    color: #1e3a5f;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  .tipos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .tipo-item {
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    padding: 1.5rem;
    border-radius: 12px;
    text-align: center;
    color: #4b5563;
  }
  .tipo-icon {
    display: block;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .faqs h2 {
    color: #1e3a5f;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  .faq-item {
    margin-bottom: 1rem;
    padding: 1.25rem;
    background: #f8fafc;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }
  .faq-item h3 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .faq-item p {
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  .sidebar {
    position: sticky;
    top: 100px;
    align-self: start;
  }
  .cta-box {
    background: #1e3a5f;
    color: #fff;
    padding: 1.5rem;
    border-radius: 16px;
    margin-bottom: 2rem;
  }
  .cta-box h3 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }
  .cta-box p {
    font-size: 0.875rem;
    opacity: 0.9;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .cta-button {
    display: block;
    background: #fff;
    color: #1e3a5f;
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }
  .cta-button:hover {
    background: #f3f4f6;
  }
  .whatsapp-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #25d366;
    color: #fff;
    padding: 0.875rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    margin-top: 1rem;
    transition: all 0.3s ease;
    animation: pulse-green 2s infinite;
  }
  .whatsapp-button:hover {
    background: #128c7e;
    transform: scale(1.02);
  }
  .whatsapp-icon {
    width: 24px;
    height: 24px;
  }
  @keyframes pulse-green {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.4);
    }
    50% {
      box-shadow: 0 0 0 12px rgba(37, 211, 102, 0);
    }
  }
  .otros-servicios {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
  }
  .otros-servicios h3 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .otros-servicios ul {
    list-style: none;
    padding: 0;
  }
  .otros-servicios li {
    margin-bottom: 0.75rem;
  }
  .otros-servicios a {
    color: #4b5563;
    font-size: 0.875rem;
    transition: color 0.2s;
  }
  .otros-servicios a:hover {
    color: #1e3a5f;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
    }
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .bento-card.bento-highlight,
    .bento-card.bento-wide {
      grid-column: span 1;
      flex-direction: column;
      text-align: center;
    }
    .tipos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
