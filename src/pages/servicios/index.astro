---
import Layout from '../../layouts/Layout.astro';
import Balsas2Img from '../../assets/balsas2.jpeg';

const servicios = [
  {
    titulo: "Mantención y Certificación de Balsas Salvavidas",
    descripcion: "Servicio técnico autorizado para inspección, certificación y mantención con cumplimiento SOLAS y directivas de la Autoridad Marítima de Chile.",
    icono: Balsas2Img.src,
    link: "/servicios/balsas-salvavidas"
  },
  {
    titulo: "Mantención y Certificación de Extintores de Incendio",
    descripcion: "Recarga, mantenimiento y certificación de extintores según DS 44 y normativa vigente.",
    icono: "🔥",
    link: "/servicios/extintores",
    enProceso: true
  },
  {
    titulo: "Mantención, Reparación y Certificación de Trajes de Inmersión",
    descripcion: "Inspección técnica, pruebas funcionales y certificación de trajes de inmersión según normativa MSC/Circ.1114.",
    icono: "🤿",
    link: "/servicios/trajes-inmersion"
  }
];
---

<Layout title="Servicios | SIMAUSTRAL">
  <section class="hero">
    <div class="hero-content">
      <h1>Nuestros Servicios</h1>
      <p>Servicios de certificación, inspección, mantención y reparación de equipos marítimos con cumplimiento normativo nacional e internacional.</p>
    </div>
  </section>

  <section class="servicios-section">
    <div class="container">
      <div class="servicios-grid">
        {servicios.map((servicio) => (
          <a href={servicio.link} class={`servicio-card ${servicio.enProceso ? 'en-proceso' : ''}`}>
            {servicio.enProceso && (
              <div class="badge-proceso">
                <span class="badge-text">PRONTO</span>
              </div>
            )}
            {servicio.icono.includes('.') ? (
              <img src={servicio.icono} alt={servicio.titulo} class="servicio-icon-img" />
            ) : (
              <div class="servicio-icon">{servicio.icono}</div>
            )}
            <h3>{servicio.titulo}</h3>
            <p>{servicio.descripcion}</p>
            <span class="servicio-link">{servicio.enProceso ? 'Ver más →' : 'Ver más →'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-content">
      <h2>¿Necesitas una cotización?</h2>
      <p>Contáctanos para recibir información sobre nuestros servicios y precios.</p>
      <a href="/contacto" class="cta-button">Solicitar Cotización</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.125rem;
    opacity: 0.9;
    line-height: 1.6;
  }

  .servicios-section {
    padding: 4rem 2rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .servicio-card {
    background: #fff;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid #e5e7eb;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .servicio-card:hover {
    border-color: #1e3a5f;
    box-shadow: 0 8px 30px rgba(30, 58, 95, 0.1);
    transform: translateY(-4px);
  }

  .servicio-card.en-proceso {
    border-color: #f59e0b;
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  }

  .servicio-card.en-proceso:hover {
    border-color: #d97706;
    box-shadow: 0 8px 30px rgba(245, 158, 11, 0.2);
  }

  .servicio-card.en-proceso::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.1), transparent);
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% {
      left: -100%;
    }
    100% {
      left: 100%;
    }
  }

  .servicio-card.en-proceso .servicio-icon,
  .servicio-card.en-proceso h3,
  .servicio-card.en-proceso p {
    opacity: 0.5;
    filter: blur(1px);
  }

  .servicio-card.en-proceso:hover .servicio-icon,
  .servicio-card.en-proceso:hover h3,
  .servicio-card.en-proceso:hover p {
    opacity: 0.7;
    filter: blur(0.5px);
  }

  .badge-proceso {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 30px;
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.5);
    z-index: 10;
    animation: pulse-badge 2s ease-in-out infinite;
  }

  @keyframes pulse-badge {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.05);
    }
  }

  .servicio-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .servicio-card h3 {
    font-size: 1.25rem;
    color: #1e3a5f;
    margin-bottom: 0.75rem;
  }

  .servicio-card p {
    color: #6b7280;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }

  .servicio-link {
    color: #1e3a5f;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .servicio-icon-img {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1rem;
  }

  .cta {
    background: #f3f4f6;
    padding: 4rem 2rem;
    text-align: center;
  }

  .cta-content h2 {
    color: #1e3a5f;
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    background: #1e3a5f;
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    transition: background 0.2s;
  }

  .cta-button:hover {
    background: #2d5a87;
  }
</style>