---
import Layout from '../../layouts/Layout.astro';

const servicios = [
  {
    titulo: "Mantención y Certificación de Balsas Salvavidas",
    descripcion: "Servicio técnico autorizado para inspección, certificación y mantención con cumplimiento SOLAS y directivas de la Autoridad Marítima de Chile.",
    icono: "🚢",
    link: "/servicios/balsas-salvavidas"
  },
  {
    titulo: "Mantención y Certificación de Extintores de Incendio",
    descripcion: "Recarga, mantenimiento y certificación de extintores según DS 44 y normativa vigente.",
    icono: "🔥",
    link: "/servicios/extintores"
  },
  {
    titulo: "Mantención y Certificación de Botes Salvavidas",
    descripcion: "Inspección, certificación y reparación de botes salvavidas según normativas internacionales.",
    icono: "🛶",
    link: "/servicios/botes-salvavidas"
  },
  {
    titulo: "Mantención y Certificación de Equipos de Protección Personal",
    descripcion: "Inspección, mantenimiento y pruebas de equipos de protección personal (EPP).",
    icono: "🦺",
    link: "/servicios/epp"
  },
  {
    titulo: "Certificación de Sistemas Fijos de Extinción",
    descripcion: "Inspección, mantención y certificación de sistemas fijos de extinción de incendios.",
    icono: "🚨",
    link: "/servicios/sistemas-fijos"
  },
  {
    titulo: "Certificación de Pruebas de Carga y Grúas",
    descripcion: "Pruebas de carga certificadas para grúas y pescantes según normativas.",
    icono: "⚖️",
    link: "/servicios/pruebas-carga"
  },
  {
    titulo: "Prácticas de Manejo de Extintores",
    descripcion: "Capacitación práctica en uso de extintores de incendio para personal naval.",
    icono: "📚",
    link: "/servicios/practicas-extintores"
  }
];
---

<Layout title="Servicios | SIMAUSTRAL">
  <section class="hero">
    <div class="hero-content">
      <h1>Nuestros Servicios</h1>
      <p>Servicios de certificación, inspección, mantención y reparación de equipos marítimos con cumplimiento normativo nacional e internacional.</p>
    </div>
  </section>

  <section class="servicios-section">
    <div class="container">
      <div class="servicios-grid">
        {servicios.map((servicio) => (
          <a href={servicio.link} class="servicio-card">
            <div class="servicio-icon">{servicio.icono}</div>
            <h3>{servicio.titulo}</h3>
            <p>{servicio.descripcion}</p>
            <span class="servicio-link">Ver más →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-content">
      <h2>¿Necesitas una cotización?</h2>
      <p>Contáctanos para recibir información sobre nuestros servicios y precios.</p>
      <a href="/contacto" class="cta-button">Solicitar Cotización</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.125rem;
    opacity: 0.9;
    line-height: 1.6;
  }

  .servicios-section {
    padding: 4rem 2rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .servicio-card {
    background: #fff;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid #e5e7eb;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .servicio-card:hover {
    border-color: #1e3a5f;
    box-shadow: 0 8px 30px rgba(30, 58, 95, 0.1);
    transform: translateY(-4px);
  }

  .servicio-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .servicio-card h3 {
    font-size: 1.25rem;
    color: #1e3a5f;
    margin-bottom: 0.75rem;
  }

  .servicio-card p {
    color: #6b7280;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }

  .servicio-link {
    color: #1e3a5f;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .cta {
    background: #f3f4f6;
    padding: 4rem 2rem;
    text-align: center;
  }

  .cta-content h2 {
    color: #1e3a5f;
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: #6b7280;
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    background: #1e3a5f;
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    transition: background 0.2s;
  }

  .cta-button:hover {
    background: #2d5a87;
  }
</style>