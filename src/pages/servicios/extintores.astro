---
import Layout from "../../layouts/Layout.astro";
import LogoGeamarImg from "../../assets/logo-geamar.png";
import LogoPrimeImg from "../../assets/logo-prime-patagonia.jpg";

const servicios = [
  { titulo: "Cargas de Botellas CO2", link: "co2-modal" },
  { titulo: "Consultorías Marítimas", link: "https://www.geamar.cl", external: true, logo: LogoGeamarImg.src },
  { titulo: "Capacitación de Seguridad Marítima", link: "https://primepatagonia.cl", external: true, logo: LogoPrimeImg.src },
];

const faqs = [
  {
    pregunta: "¿Cada cuánto se debe realizar la mantención?",
    respuesta:
      "Generalmente una vez al año, según normativa vigente y requerimientos del fabricante.",
  },
  {
    pregunta: "¿Qué incluye la certificación?",
    respuesta:
      "Inspección completa, recarga, pruebas de funcionamiento y emisión de certificado autorizado.",
  },
  {
    pregunta: "¿Qué documentación recibo?",
    respuesta:
      "Certificado de mantención, protocolo de pruebas y sticker de certificación vigente.",
  },
];
---

<Layout title="Mantención y Certificación de Extintores | SIMAUSTRAL">
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Home</a> / <a href="/servicios">Servicios</a> / Extintores
      </nav>
      <h1>Mantención y Certificación de Extintores de Incendio</h1>
      <p class="subtitle">
        Recarga, mantenimiento y certificación de extintores según DS 44 y
        normativa vigente.
      </p>
    </div>
  </section>

  <section class="main-content">
    <div class="container">
      <div class="blur-overlay">
        <div class="pronto-banner">
          <div class="pronto-text">PRONTO</div>
          <p>Este servicio estará disponible pronto</p>
          <a href="/contacto" class="pronto-contact">Contáctanos para más información →</a>
        </div>
        <div class="main-column">
            <section class="hero-image">
              <img
                src="https://images.pexels.com/photos/4916620/pexels-photo-4916620.jpeg"
                alt="Extintores de incendio"
              />
            </section>

            <section class="bento-grid">
              <div class="bento-card bento-highlight">
                <div class="bento-icon">🔥</div>
                <h3>Extintores de Incendio</h3>
                <p>
                  <span class="subs">
                    Recarga, mantenimiento y certificación según DS 44.</span
                  >
                </p>
              </div>
              <div class="bento-card">
                <div class="bento-icon">🔍</div>
                <h4>Inspección Visual</h4>
                <p>Verificación de estado físico, precinto y presión.</p>
              </div>
              <div class="bento-card">
                <div class="bento-icon">🔄</div>
                <h4>Recarga</h4>
                <p>Reemplazo del agente extintor según tipo.</p>
              </div>
              <div class="bento-card bento-wide">
                <div class="bento-icon">📜</div>
                <h4>Certificación</h4>
                <p>
                  Emisión de certificado y etiquetado conforme a normativa.
                  Pruebas hidrostáticas incluidas.
                </p>
              </div>
            </section>

          <section class="tipos">
            <h2>Tipos de extintores que atendemos</h2>
            <div class="tipos-grid">
              <div class="tipo-item">
                <span class="tipo-icon">🔴</span><span>Polvo químico ABC</span>
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">💧</span><span>Agua</span>
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">🫧</span><span>Espuma</span>
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">❄️</span><span>CO2</span>
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">⚡</span><span>Equipos eléctricos</span>
              </div>
            </div>
          </section>

          <section class="faqs">
            <h2>Preguntas Frecuentes</h2>
            {
              faqs.map((faq) => (
                <div class="faq-item">
                  <>
                    <h3>{faq.pregunta}</h3>
                    <p>{faq.respuesta}</p>
                  </>
                </div>
              ))
            }
          </section>
        </div>

        <aside class="sidebar">
          <div class="cta-box">
            <h3>¿Necesitas cotizar?</h3><p>
              Te ayudamos con tu cotización rápidamente.
            </p><a href="/contacto" class="cta-button">Solicitar Cotización</a
            ><a
              href="https://wa.me/56979799006"
              target="_blank"
              class="whatsapp-button"
              ><svg
                class="whatsapp-icon"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path></svg
              >Contactar por WhatsApp</a
            >
          </div>
          <div class="otros-servicios">
            <h3>Otros Servicios</h3><ul>
              {
                servicios.map((s) => (
                  <li>
                    <a
                      href={s.link === "co2-modal" ? "#" : s.link}
                      class={s.link === "co2-modal" ? "open-modal" : ""}
                      target={s.external ? "_blank" : "_self"}
                      rel={s.external ? "noopener noreferrer" : ""}
                      data-modal="co2"
                    >
                      {s.logo && <img src={s.logo} alt="" class="servicio-logo" />}
                      {s.titulo}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
      </div>
    </div>
  </section>

  <div id="co2-modal" class="modal-overlay">
    <div class="modal-content">
      <button class="modal-close">&times;</button>
      <h2 class="modal-title">🔋 Carga de Botellas CO2</h2>
      <p class="modal-description">Servicio especializado de recarga de extintores y botellas de CO2 para equipos de seguridad marítima. Cumplimos con los más altos estándares de calidad y normativas vigentes.</p>
      
      <div class="bento-grid">
        <div class="bento-card">
          <div class="bento-icon">🔋</div>
          <h4>Recarga Profesional</h4>
          <p>Uso de CO2 de alta pureza para garantizar la efectividad del agente extintor</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">✓</div>
          <h4>Certificación</h4>
          <p>Documentación y certificación de cada carga realizada</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">⚡</div>
          <h4>Rápido Turno</h4>
          <p>Procesos eficientes para minimizar el tiempo de espera</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">📋</div>
          <h4>Normativa DS 44</h4>
          <p>Cumplimiento total con el Decreto Supremo 44 y normativas marítimas</p>
        </div>
      </div>
      
      <div class="modal-cta">
        <a href="/contacto" class="cta-button">Solicitar Cotización</a>
        <a href="https://wa.me/56979799006" target="_blank" class="whatsapp-button">
          <svg class="whatsapp-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .page-header {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 3rem 2rem;
  }
  .breadcrumbs {
    font-size: 0.875rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }
  .breadcrumbs a {
    color: #fff;
    text-decoration: underline;
  }
  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .subtitle {
    font-size: 1.125rem;
    opacity: 0.9;
    max-width: 700px;
    line-height: 1.6;
  }
  .main-content {
    padding: 3rem 0;
  }

  .blur-overlay {
    position: relative;
  }

  .blur-overlay::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(3px);
    z-index: 5;
    border-radius: 16px;
  }

  .blur-overlay .main-column,
  .blur-overlay .sidebar {
    opacity: 0.3;
    filter: blur(2px);
  }

  .pronto-banner {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    text-align: center;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    padding: 3rem 4rem;
    border-radius: 20px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 90%;
  }

  .pronto-text {
    font-size: 5rem;
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-shadow: 4px 4px 8px rgba(0, 0, 0, 0.3);
    animation: pulse-pronto 2s ease-in-out infinite;
  }

  @keyframes pulse-pronto {
    0%, 100% {
      transform: scale(1);
      text-shadow: 4px 4px 8px rgba(0, 0, 0, 0.3);
    }
    50% {
      transform: scale(1.02);
      text-shadow: 6px 6px 15px rgba(0, 0, 0, 0.4);
    }
  }

  .pronto-banner p {
    color: #fff;
    font-size: 1.25rem;
    margin-top: 1rem;
    opacity: 0.95;
  }

  .pronto-contact {
    display: inline-block;
    margin-top: 1.5rem;
    background: #fff;
    color: #d97706;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .pronto-contact:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
  }
  .main-column section {
    margin-bottom: 3rem;
  }

  .hero-image {
    margin-bottom: 2rem;
    border-radius: 16px;
    overflow: hidden;
  }
  .hero-image img {
    width: 100%;
    height: 350px;
    object-fit: cover;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .bento-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }
  .bento-card:hover {
    border-color: #1e3a5f;
    box-shadow: 0 8px 30px rgba(30, 58, 95, 0.1);
    transform: translateY(-4px);
  }
  .bento-card.bento-highlight {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    grid-column: span 3;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .bento-card.bento-highlight h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .bento-card.bento-highlight p {
    opacity: 0.9;
  }
  .bento-card.bento-wide {
    grid-column: span 2;
  }
  .bento-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .bento-card h4 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .bento-card p {
    color: #6b7280;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }
  .subs {
    color: #c3c4c4;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  .tipos h2 {
    color: #1e3a5f;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  .tipos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .tipo-item {
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    padding: 1.5rem;
    border-radius: 12px;
    text-align: center;
    color: #4b5563;
  }
  .tipo-icon {
    display: block;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .faqs h2 {
    color: #1e3a5f;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  .faq-item {
    margin-bottom: 1rem;
    padding: 1.25rem;
    background: #f8fafc;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
  }
  .faq-item h3 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .faq-item p {
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  .sidebar {
    position: sticky;
    top: 100px;
    align-self: start;
  }
  .cta-box {
    background: #1e3a5f;
    color: #fff;
    padding: 1.5rem;
    border-radius: 16px;
    margin-bottom: 2rem;
  }
  .cta-box h3 {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }
  .cta-box p {
    font-size: 0.875rem;
    opacity: 0.9;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .cta-button {
    display: block;
    background: #fff;
    color: #1e3a5f;
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }
  .cta-button:hover {
    background: #f3f4f6;
  }
  .whatsapp-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #25d366;
    color: #fff;
    padding: 0.875rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    margin-top: 1rem;
    transition: all 0.3s ease;
    animation: pulse-green 2s infinite;
  }
  .whatsapp-button:hover {
    background: #128c7e;
    transform: scale(1.02);
  }
  .whatsapp-icon {
    width: 24px;
    height: 24px;
  }
  @keyframes pulse-green {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.4);
    }
    50% {
      box-shadow: 0 0 0 12px rgba(37, 211, 102, 0);
    }
  }
  .otros-servicios {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
  }
  .otros-servicios h3 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .otros-servicios ul {
    list-style: none;
    padding: 0;
  }
  .otros-servicios li {
    margin-bottom: 0.75rem;
  }
  .otros-servicios a {
    color: #4b5563;
    font-size: 0.875rem;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .otros-servicios a:hover {
    color: #1e3a5f;
  }
  .servicio-logo {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
    }
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .bento-card.bento-highlight,
    .bento-card.bento-wide {
      grid-column: span 1;
      flex-direction: column;
      text-align: center;
    }
    .tipos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .modal-overlay.active {
    display: flex;
  }
  .modal-content {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    max-width: 700px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    animation: modalSlide 0.3s ease;
  }
  @keyframes modalSlide {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    color: #6b7280;
    transition: color 0.2s;
  }
  .modal-close:hover {
    color: #1e3a5f;
  }
  .modal-title {
    color: #1e3a5f;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .modal-description {
    color: #6b7280;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .modal-cta {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .modal-cta .cta-button {
    background: #1e3a5f;
    color: #fff;
    text-align: center;
    padding: 0.875rem;
    border-radius: 8px;
    font-weight: 600;
  }
  .modal-cta .cta-button:hover {
    background: #2d5a87;
  }
  .modal-cta .whatsapp-button {
    animation: none;
  }
</style>

<script>
  const modal = document.getElementById('co2-modal');
  const modalTriggers = document.querySelectorAll('.open-modal[data-modal="co2"]');
  const closeBtn = modal?.querySelector('.modal-close');

  modalTriggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      modal?.classList.add('active');
      document.body.style.overflow = 'hidden';
    });
  });

  closeBtn?.addEventListener('click', () => {
    modal?.classList.remove('active');
    document.body.style.overflow = '';
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('active')) {
      modal?.classList.remove('active');
      document.body.style.overflow = '';
    }
  });
</script>
