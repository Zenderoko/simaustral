                      ></path>
                    </g>
                  </svg>
                </span><span>Naves Mayores de Tráfico Nacional</span>
              </div>
              <div class="cliente-item">
                <span class="cliente-icon">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path
                      d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"
                    ></path>
                    <path
                      d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"
                    ></path>
                    <path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"></path>
                    <path d="M12 10V4.5a.5.5 0 0 1 1 0V4a1 1 0 0 1 1 1v4"
                    ></path>
                  </svg>
                </span><span>Naves Menores</span>
              </div>
              <div class="cliente-item">
                <span class="cliente-icon">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
