---
import Layout from "../../layouts/Layout.astro";
import SalvamentoBg from "../../assets/salvamento-bg.jpg";
import PirotecniaIcon from "../../assets/pirotecnia-icon.jpg";
import BengalaImg from "../../assets/bengala.png";
import BombaHumoImg from "../../assets/bombahumo.png";
import CoheteImg from "../../assets/coheteparacaida.png";
import LogoGeamarImg from "../../assets/logo-geamar.png";
import LogoPrimeImg from "../../assets/logo-prime-patagonia.jpg";
import LogoCo2 from "../../assets/co2.jpeg";
import LogoGcitec from "../../assets/gcitec-logo.png";
import LogoImpreLab from "../../assets/Logo-Inprelab.jpeg";

const servicios = [
  { titulo: "Cargas de Botellas CO2", link: "co2-modal", logo: LogoCo2.src },
  {
    titulo: "Consultorías Marítimas",
    link: "https://www.geamar.cl",
    external: true,
    logo: LogoGeamarImg.src,
  },
  {
    titulo: "Capacitación de Seguridad Marítima",
    link: "https://primepatagonia.cl",
    external: true,
    logo: LogoPrimeImg.src,
  },
];

const faqs = [
  {
    pregunta: "¿Cuáles son los tipos de señales de salvamento que ofrecen?",
    respuesta:
      "Ofrecemos Bengalas de Mano MK8, Bombas de Humo Naranja de Comet y Cohetes con Paracaídas, todos certificados SOLAS y aprobados por DIRECTEMAR.",
  },
  {
    pregunta: "¿Cada cuánto deben reemplazarse las bengalas?",
    respuesta:
      "Las señales pirotécnicas tienen una vida útil de 3 años desde su fecha de fabricación. Es fundamental reemplazarlas antes de su vencimiento para garantizar su funcionamiento en una emergencia.",
  },
  {
    pregunta: "¿Qué normativas cumplen estos equipos?",
    respuesta:
      "Todos los productos cuentan con certificación SOLAS 74/96, aprobación MED y cumplen con las exigencias de la Autoridad Marítima de Chile (DIRECTEMAR) y el Código Internacional de Dispositivos de Salvamento (IDS).",
  },
];
---

<Layout
  title="Señales de Salvamento - Pirotecnia Marina"
  description="Comercialización de señales de salvamento pirotécnicas en Chiloé: Bengalas de Mano MK8, Bombas de Humo Naranja de Comet y Cohetes con Paracaídas. Certificación SOLAS. Despachos a todo Chile."
>
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Home</a> / <a href="/servicios">Servicios</a> / Señales de Salvamento
      </nav>
      <h1>Comercialización de Señales de Salvamento (Pirotecnia)</h1>
      <p class="subtitle">
        Bengalas de Mano MK8, Bombas de Humo Comet y Cohetes con Paracaídas
        certificados SOLAS
      </p>
    </div>
  </section>

  <section class="main-content">
    <div class="container">
      <div class="content-grid">
        <div class="main-column">
          <section class="hero-image">
            <img src={SalvamentoBg.src} alt="Señales de salvamento pirotécnicas" />
          </section>

          <section class="bento-grid">
            <div class="bento-card bento-highlight">
              <img
                src={SalvamentoBg.src}
                alt="Señales de Salvamento"
                class="piro-icon"
              />
              <h3>Señales de Salvamento</h3>
              <p>
                <span class="subs"
                  >Comercializamos Bengalas de Mano MK8, Bombas de Humo Naranja
                  de Comet y Cohetes con Paracaídas, todos aprobados SOLAS y
                  diseñados para operaciones de emergencia y rescate marítimo.
                  Cumplen con el
                  <a
                    href="https://www.directemar.cl/directemar/site/docs/20220623/20220623152936/codigo_ids_version__cl_23_6_22_caa_rrt_actualizado_al_10_de_abril_de_2026.pdf"
                    target="_blank"
                    style="color: #f59e0b;">Código I.D.S.</a
                  >
                  y las exigencias de DIRECTEMAR.</span
                >
              </p>
            </div>
            <div class="bento-card">
              <img
                src={BengalaImg.src}
                alt="Bengala de Mano MK8"
                class="product-icon"
              />
              <h4>Bengalas de Mano MK8</h4>
              <p>
                Bengala roja portátil marca Pains Wessex, con 60 segundos de
                combustión e intensidad lumínica superior a 15.000 candelas.
                Ideal para señalamiento de corto alcance en operaciones diurnas
                y nocturnas. Certificación SOLAS.
              </p>
            </div>

            <div class="bento-card">
              <img
                src={CoheteImg.src}
                alt="Cohetes con Paracaídas"
                class="product-icon"
              />
              <h4>Cohetes con Paracaídas</h4>
              <p>
                Cohetes de largo alcance que alcanzan 300 metros de altura con
                paracaídas incorporado. Visibles hasta 40 millas náuticas.
                Combustión mínima de 40 segundos. Certificación SOLAS.
              </p>
            </div>
            <div class="bento-card bento-wide">
              <img
                src={BombaHumoImg.src}
                alt="Bombas de Humo Naranja de Comet"
                class="product-icon"
              />
              <h4>Bombas de Humo Naranja de Comet</h4>
              <p>
                Señales de humo flotantes marca Comet, con duración superior a 3
                minutos para uso diurno. Emiten humo naranja de alta visibilidad
                para localización precisa. Certificación SOLAS.
              </p>
            </div>
          </section>

          <section class="tipos">
            <h2>Productos que comercializamos</h2>
            <div class="tipos-grid">
              <div class="tipo-item">
                <span class="tipo-icon">🔴</span><span
                  >Bengala de Mano MK8</span
                >
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">🟠</span><span
                  >Bomba de Humo Naranja de Comet</span
                >
              </div>
              <div class="tipo-item">
                <span class="tipo-icon">🚀</span><span
                  >Cohete con Paracaídas</span
                >
              </div>
            </div>
          </section>

          <section class="solas-info">
            <h2>Dotación SOLAS exigida</h2>
            <p class="solas-subtitle">
              Según el Convenio SOLAS y el Código IDS, la dotación mínima de
              señales pirotécnicas para embarcaciones es:
            </p>
            <div class="solas-grid">
              <div class="solas-card pack-a">
                <div class="pack-header">
                  <span class="pack-badge">Pack A</span>
                  <span class="pack-desc">Embarcaciones mayores</span>
                </div>
                <ul class="pack-list">
                  <li>
                    <span class="pack-icon">🔴</span>
                    <span>6 Bengalas de Mano</span>
                  </li>
                  <li>
                    <span class="pack-icon">🚀</span>
                    <span>4 Cohetes con Paracaídas</span>
                  </li>
                  <li>
                    <span class="pack-icon">🟠</span>
                    <span>2 Señales de Humo por balsa/bote</span>
                  </li>
                </ul>
              </div>
              <div class="solas-card pack-b">
                <div class="pack-header">
                  <span class="pack-badge">Pack B</span>
                  <span class="pack-desc">Embarcaciones menores</span>
                </div>
                <ul class="pack-list">
                  <li>
                    <span class="pack-icon">🔴</span>
                    <span>3 Bengalas de Mano</span>
                  </li>
                  <li>
                    <span class="pack-icon">🚀</span>
                    <span>2 Cohetes con Paracaídas</span>
                  </li>
                  <li>
                    <span class="pack-icon">🟠</span>
                    <span>1 Señal de Humo por balsa/bote</span>
                  </li>
                </ul>
              </div>
            </div>
          </section>

          <section class="clientes">
            <h2>Nuestros clientes</h2>
            <div class="clientes-grid">
              <div class="cliente-item">
                <span class="cliente-icon">
                  <svg
                    version="1.1"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 435.926 435.926"
                    style="fill:#1e3a5f;"
                  >
                    <g>
                      <path
