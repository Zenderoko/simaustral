          </div>
          <div class="otros-servicios">
            <h3>Otros Servicios</h3><ul>
              {
                servicios.map((s) => (
                  <li>
                    <a
                      href={s.link === "co2-modal" ? "#" : s.link}
                      class={s.link === "co2-modal" ? "open-modal" : ""}
                      target={s.external ? "_blank" : "_self"}
                      rel={s.external ? "noopener noreferrer" : ""}
                      data-modal="co2"
                    >
                      {s.logo && (
                        <img src={s.logo} alt="" class="servicio-logo" />
                      )}
                      {s.titulo}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div id="co2-modal" class="modal-overlay">
    <div class="modal-content">
      <button class="modal-close">&times;</button>
      <h2 class="modal-title">🔋 Carga de Botellas CO2</h2>
      <p class="modal-description">
        Servicio especializado de recarga de extintores y botellas de CO2 para
        equipos de seguridad marítima. Cumplimos con los más altos estándares de
        calidad y normativas vigentes.
      </p>

      <div class="bento-grid">
        <div class="bento-card">
          <div class="bento-icon">🔋</div>
          <h4>Recarga Profesional</h4>
          <p>
            Uso de CO2 de alta pureza para garantizar la efectividad del agente
            extintor
          </p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">✓</div>
          <h4>Certificación</h4>
          <p>Documentación y certificación de cada carga realizada</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">⚡</div>
          <h4>Rápido Turno</h4>
          <p>Procesos eficientes para minimizar el tiempo de espera</p>
        </div>
        <div class="bento-card">
          <div class="bento-icon">📋</div>
          <h4>Normativa DS 44</h4>
          <p>
            Cumplimiento total con el Decreto Supremo 44 y normativas marítimas
          </p>
        </div>
      </div>

      <div class="modal-cta">
        <a href="/contacto" class="cta-button">Solicitar Cotización</a>
        <a
          href="https://wa.me/56979799006"
          target="_blank"
          class="whatsapp-button"
        >
          <svg class="whatsapp-icon" viewBox="0 0 24 24" fill="currentColor"
