---
import Layout from "../layouts/Layout.astro";
import EntradaImg from "../assets/entrada.jpeg";
import Balsas2Img from "../assets/balsas2.jpeg";
---

<Layout title="SIMAUSTRAL - Certificación y Mantención de Equipos Marítimos">
  <section class="hero">
    <div class="hero-content">
      <h1>Certificación y Mantención de Equipos Marítimos</h1>
      <p>Servicios especializados con cumplimiento SOLAS</p>
      <div class="hero-buttons">
        <a href="/servicios" class="btn-primary">Ver Servicios</a>
        <a href="/contacto" class="btn-secondary">Contactar</a>
      </div>
    </div>
  </section>

  <section
    class="features"
    style={`background-image: linear-gradient(rgba(30, 58, 95, 0.85), rgba(30, 58, 95, 0.85)), url(${EntradaImg.src});`}
  >
    <div class="container">
      <h2>¿Por qué elegirnos?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3>Personal Certificado</h3>
          <p>
            Contamos con personal acreditado por <a
              href="https://www.directemar.cl/">DIRECTEMAR</a
            > para realizar la inspección de balsas salvavidas según normativa del
            Convenio SOLAS
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              <path d="M12 2v2"></path>
              <path d="M12 8v1"></path>
              <path d="M4.93 4.93l1.41 1.41"></path>
              <path d="M7.76 7.76L9.17 9.17"></path>
              <path d="M2 12h2"></path>
            </svg>
          </div>
          <h3>Confianza</h3>
          <p>
            La confianza y experiencia de nuestros técnicos son la base de un
            servicio fiable y de calidad.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </div>
          <h3>Transparencia</h3>
          <p>
            Nuestra transparencia se refleja en cada revisión de balsas
            salvavidas, entregando siempre repuestos, mantenimiento y elementos
            debidamente autorizados, garantizando su fiabilidad en situaciones
            de emergencia en el mar.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <polyline points="9 12 12 15 16 10"></polyline>
            </svg>
          </div>
          <h3>Responsabilidad</h3>
          <p>
            Asumimos los mantenimientos, reparaciones e inspecciones, son
            efectuadas con responsabilidad, usando las técnicas de mayor
            exigencia, con el objeto de cumplir los requisitos de operatividad y
            diseño, establecidos a nivel internacional. Porque la seguridad de
            la vida humana en el mar no es un juego.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="servicios-preview">
    <div class="container">
      <h2>Nuestros Servicios</h2>
      <div class="servicios-list">
        <a href="/servicios/balsas-salvavidas" class="servicio-item">
          <img src={Balsas2Img.src} alt="Balsas Salvavidas" class="servicio-img" />
          <div class="servicio-info">
            <h3>Balsas Salvavidas</h3>
            <p>Inspección, certificación y mantención</p>
          </div>
        </a>
        <a href="/servicios/extintores" class="servicio-item">
          <span class="servicio-icon">🔥</span>
          <div class="servicio-info">
            <h3>Extintores de Incendio</h3>
            <p>Recarga y certificación DS 44</p>
          </div>
        </a>
        <a href="/servicios/trajes-inmersion" class="servicio-item">
          <span class="servicio-icon">🤿</span>
          <div class="servicio-info">
            <h3>Trajes de Inmersión</h3>
            <p>Mantención, reparación y certificación</p>
          </div>
        </a>
      </div>
      <div class="servicios-cta">
        <a href="/servicios" class="btn-link">Ver todos los servicios →</a>
      </div>
    </div>
  </section>

  <section class="contact-cta">
    <div class="container">
      <h2>¿Necesitas una cotización?</h2>
      <p>Contáctanos y te responderemos con precio y fecha disponibles.</p>
      <a href="/contacto" class="btn-primary">Solicitar Cotización</a>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 6rem 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .hero p {
    font-size: 1.25rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn-primary,
  .btn-secondary {
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #fff;
    color: #1e3a5f;
  }

  .btn-primary:hover {
    background: #f3f4f6;
  }

  .btn-secondary {
    background: transparent;
    color: #fff;
    border: 2px solid #fff;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .features {
    padding: 5rem 2rem;
    background-size: cover;
    background-position: center;
  }

  .features h2 {
    text-align: center;
    color: #1e3a5f;
    font-size: 1.75rem;
    margin-bottom: 3rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    padding: 2rem 1.5rem;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.95);
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
    border-color: #f59e0b;
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: #fff;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: transform 0.3s ease;
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.1);
  }

  .feature-card h3 {
    color: #1e3a5f;
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .feature-card p {
    color: #4b5563;
    line-height: 1.6;
    font-size: 0.9rem;
  }

  .feature-card a {
    font-size: 20px;
    font-weight: bold;
    color: #1e3a5f;
  }

  .feature-card a:hover {
    color: #f59e0b;
  }

  .servicios-preview {
    padding: 5rem 2rem;
    background: #f3f4f6;
  }

  .servicios-preview h2 {
    text-align: center;
    color: #1e3a5f;
    font-size: 1.75rem;
    margin-bottom: 2rem;
  }

  .servicios-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .servicio-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: #fff;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    transition: all 0.2s;
  }

  .servicio-item:hover {
    border-color: #1e3a5f;
    transform: translateX(4px);
  }

  .servicio-icon {
    font-size: 1.75rem;
  }

  .servicio-img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 8px;
  }

  .servicio-info h3 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .servicio-info p {
    color: #6b7280;
    font-size: 0.875rem;
  }

  .servicios-cta {
    text-align: center;
    margin-top: 2rem;
  }

  .banner-section {
    padding: 3rem 2rem;
    background: #fff;
  }

  .banner-section .container {
    display: flex;
    justify-content: center;
  }

  .banner-img {
    max-width: 100%;
    width: auto;
    max-height: 400px;
    border-radius: 12px;
  }

  .btn-link {
    color: #1e3a5f;
    font-weight: 600;
  }

  .btn-link:hover {
    text-decoration: underline;
  }

  .contact-cta {
    padding: 5rem 2rem;
    background: #1e3a5f;
    color: #fff;
    text-align: center;
  }

  .contact-cta h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .contact-cta p {
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .contact-cta .btn-primary {
    display: inline-block;
  }

  @media (max-width: 1100px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .feature-card {
      padding: 1.5rem;
    }
  }
</style>
