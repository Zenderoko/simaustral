---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SIMAUSTRAL - Certificación y Mantención de Equipos Marítimos">
  <section class="hero">
    <div class="hero-content">
      <h1>Certificación y Mantención de Equipos Marítimos</h1>
      <p>
        Servicios especializados con cumplimiento SOLAS y normativas de la
        Autoridad Marítima de Chile.
      </p>
      <div class="hero-buttons">
        <a href="/servicios" class="btn-primary">Ver Servicios</a>
        <a href="/contacto" class="btn-secondary">Contactar</a>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <h2>¿Por qué elegirnos?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">✓</div>
          <h3>Personal Autorizado</h3>
          <p>
            Contamos con personal certificado y estaciones autorizadas por
            Directemar (DGTM).
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">✓</div>
          <h3>Capacidad Anual Elevada</h3>
          <p>
            Hasta 250 certificaciones anuales con equipos auxiliares
            disponibles.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">✓</div>
          <h3>Documentación Completa</h3>
          <p>
            Certificados listos para fiscalización y auditorías internacionales.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="servicios-preview">
    <div class="container">
      <h2>Nuestros Servicios</h2>
      <div class="servicios-list">
        <a href="/servicios/balsas-salvavidas" class="servicio-item">
          <span class="servicio-icon">🚢</span>
          <div class="servicio-info">
            <h3>Balsas Salvavidas</h3>
            <p>Inspección, certificación y mantención</p>
          </div>
        </a>
        <a href="/servicios/extintores" class="servicio-item">
          <span class="servicio-icon">🔥</span>
          <div class="servicio-info">
            <h3>Extintores de Incendio</h3>
            <p>Recarga y certificación DS 44</p>
          </div>
        </a>
        <a href="/servicios/botes-salvavidas" class="servicio-item">
          <span class="servicio-icon">🛶</span>
          <div class="servicio-info">
            <h3>Botes Salvavidas</h3>
            <p>Certificación y reparación</p>
          </div>
        </a>
        <a href="/servicios/sistemas-fijos" class="servicio-item">
          <span class="servicio-icon">🚨</span>
          <div class="servicio-info">
            <h3>Sistemas Fijos de Extinción</h3>
            <p>Inspección y certificación</p>
          </div>
        </a>
      </div>
      <div class="servicios-cta">
        <a href="/servicios" class="btn-link">Ver todos los servicios →</a>
      </div>
    </div>
  </section>

  <!-- <section class="banner-section">
    <div class="container">
      <img src="https://stmservicios.cl/wp-content/uploads/2025/06/Texto-800-x-800-px-87.png" alt="Servicios Marítimos" class="banner-img" />
    </div>
  </section> -->

  <section class="contact-cta">
    <div class="container">
      <h2>¿Necesitas una cotización?</h2>
      <p>Contáctanos y te responderemos con precio y fecha disponibles.</p>
      <a href="/contacto" class="btn-primary">Solicitar Cotización</a>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
    color: #fff;
    padding: 6rem 2rem;
    text-align: center;
  }

  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .hero p {
    font-size: 1.25rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn-primary,
  .btn-secondary {
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #fff;
    color: #1e3a5f;
  }

  .btn-primary:hover {
    background: #f3f4f6;
  }

  .btn-secondary {
    background: transparent;
    color: #fff;
    border: 2px solid #fff;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .features {
    padding: 5rem 2rem;
    background: #fff;
  }

  .features h2 {
    text-align: center;
    color: #1e3a5f;
    font-size: 1.75rem;
    margin-bottom: 3rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    padding: 2rem;
    border-radius: 12px;
    background: #f8f9fa;
    text-align: center;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    background: #1e3a5f;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    margin: 0 auto 1rem;
  }

  .feature-card h3 {
    color: #1e3a5f;
    margin-bottom: 0.75rem;
  }

  .feature-card p {
    color: #6b7280;
    line-height: 1.6;
  }

  .servicios-preview {
    padding: 5rem 2rem;
    background: #f8f9fa;
  }

  .servicios-preview h2 {
    text-align: center;
    color: #1e3a5f;
    font-size: 1.75rem;
    margin-bottom: 2rem;
  }

  .servicios-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .servicio-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: #fff;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    transition: all 0.2s;
  }

  .servicio-item:hover {
    border-color: #1e3a5f;
    transform: translateX(4px);
  }

  .servicio-icon {
    font-size: 1.75rem;
  }

  .servicio-info h3 {
    color: #1e3a5f;
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .servicio-info p {
    color: #6b7280;
    font-size: 0.875rem;
  }

  .servicios-cta {
    text-align: center;
    margin-top: 2rem;
  }

  .banner-section {
    padding: 3rem 2rem;
    background: #fff;
  }

  .banner-section .container {
    display: flex;
    justify-content: center;
  }

  .banner-img {
    max-width: 100%;
    width: auto;
    max-height: 400px;
    border-radius: 12px;
  }

  .btn-link {
    color: #1e3a5f;
    font-weight: 600;
  }

  .btn-link:hover {
    text-decoration: underline;
  }

  .contact-cta {
    padding: 5rem 2rem;
    background: #1e3a5f;
    color: #fff;
    text-align: center;
  }

  .contact-cta h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .contact-cta p {
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .contact-cta .btn-primary {
    display: inline-block;
  }
</style>
