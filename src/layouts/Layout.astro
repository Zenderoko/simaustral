---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Servicios de certificación y mantención de equipos marítimos"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <header class="header">
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/logo.png" alt="SIMAUSTRAL" class="logo-img" />
          <span class="logo-text">SIMAUSTRAL</span>
        </a>
        <nav class="nav">
          <a href="/">Inicio</a>
          <a href="/servicios">Servicios</a>
          <a href="/galeria">Galería</a>
          <a href="/contacto">Contacto</a>
        </nav>

      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-container">
        <div class="footer-section">
          <h3>SIMAUSTRAL</h3>
          <p>Servicios de certificación y mantención de equipos marítimos.</p>
        </div>
        <div class="footer-section">
          <h4>Contacto</h4>
          <p>El Estero Nro 60, Dalcahue, Chiloé</p>
          <p>+56979799006</p>
        </div>
        <div class="footer-section">
          <h4>Enlaces</h4>
          <a href="/servicios">Servicios</a>
          <a href="/galeria">Galería</a>
          <a href="/contacto">Contacto</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 SIMAUSTRAL. Todos los derechos reservados.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: "Inter", sans-serif;
    background: #f8f9fa;
    color: #333;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  .header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-img {
    height: auto;
    width: 100px;
  }

  .logo-text {
    font-family: "Calibri", sans-serif;
    font-size: 40px;
    font-weight: 800;
    color: #1e3a5f;
  }

  .nav {
    display: flex;
    gap: 4rem;
  }

  .nav a {
    font-weight: 600;
    color: #4b5563;
    transition: color 0.2s;
    font-size: 23px;
  }

  .nav a:hover {
    color: orange;
  }

  .contact-phone {
    font-weight: 600;
    color: #1e3a5f;
  }

  .footer {
    background: #1e3a5f;
    color: #fff;
    margin-top: 4rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .footer-section h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .footer-section h4 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: #94a3b8;
  }

  .footer-section p,
  .footer-section a {
    color: #cbd5e1;
    line-height: 1.6;
  }

  .footer-section a:hover {
    color: #fff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.5rem 2rem;
    text-align: center;
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      gap: 1rem;
      padding: 0.75rem 1rem;
    }

    .nav {
      gap: 1.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav a {
      font-size: 16px;
    }

    .logo-text {
      font-size: 28px;
    }

    .logo-img {
      width: 70px;
    }
  }
</style>