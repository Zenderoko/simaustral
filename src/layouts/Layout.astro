---
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Servicios de certificación y mantención de equipos marítimos, extintores, balsas salvavidas y trajes de inmersión en Chiloé, Chile.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "SIMAUSTRAL";
const imageUrl = "https://www.simaustral.cl/logo.png";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title} | {siteName}</title>
    <meta name="title" content={`${title} | ${siteName}`} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="certificación marítima, mantención equipos marítimos, extintores, balsas salvavidas, trajes inmersión, Chiloé, Dalcahue, Chile, seguridad marítima"
    />
    <meta name="author" content="SIMAUSTRAL" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="Spanish" />
    <meta name="revisit-after" content="7 days" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | ${siteName}`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={imageUrl} />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "SIMAUSTRAL",
        "description": "Servicios de certificación y mantención de equipos marítimos en Chiloé",
        "url": "https://www.simaustral.cl",
        "logo": "https://www.simaustral.cl/logo.png",
        "telephone": "+56979799006",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "El Estero Nro 60",
          "addressLocality": "Dalcahue",
          "addressRegion": "Los Lagos",
          "addressCountry": "CL"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -42.3752197,
          "longitude": -73.6439136
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        "priceRange": "$$",
        "areaServed": {
          "@type": "State",
          "name": "Los Lagos"
        },
        "serviceType": [
          "Certificación de equipos marítimos",
          "Mantención de extintores",
          "Balsas salvavidas",
          "Trajes de inmersión"
        ]
      }
    </script>

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body>
    <header class="header">
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/logo.png" alt="SIMAUSTRAL" class="logo-img" />
          <span class="logo-text">SIMAUSTRAL</span>
        </a>
        <nav class="nav">
          <a href="/">Inicio</a>
          <a href="/servicios">Servicios</a>
          <a href="/galeria">Galería</a>
          <a href="/contacto">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-container">
        <div class="footer-section">
          <h3>SIMAUSTRAL</h3>
          <p>Servicios de certificación y mantención de equipos marítimos.</p>
        </div>
        <div class="footer-section">
          <h4>Contacto</h4>
          <p>El Estero Nro 60, Dalcahue, Chiloé</p>
          <p>+56979799006</p>
          <a
            href="https://www.google.com/maps/place/Simaustral/@-42.3749783,-73.6445156,204m/data=!3m1!1e3!4m6!3m5!1s0x96220d507b3b66ef:0xcac336d5069d9786!8m2!3d-42.3748204!4d-73.6435375!16s%2Fg%2F11z3_6hnb9?entry=ttu&g_ep=EgoyMDI2MDQwNy4wIKXMDSoASAFQAw%3D%3D"
            target="_blank"
            rel="noopener"
            class="footer-map-link"
          >
            <iframe
              src="https://www.google.com/maps?q=-42.374808397434855,-73.64348754750623&t=m&z=17&output=embed&iwloc=near"
              width="180"
              height="100"
              style="border:0; border-radius: 6px;"
              loading="lazy"
              class="footer-map-iframe"
            >
            </iframe>
            <span>Ver en Google Maps</span>
          </a>
        </div>
        <div class="footer-section">
          <h4>Enlaces</h4>
          <a href="/servicios">Servicios</a>
          <a href="/galeria">Galería</a>
          <a href="/contacto">Contacto</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 SIMAUSTRAL. Todos los derechos reservados.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: "Inter", sans-serif;
    background: #f8f9fa;
    color: #333;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  .header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-img {
    height: auto;
    width: 100px;
  }

  .logo-text {
    font-family: "Calibri", sans-serif;
    font-size: 40px;
    font-weight: 800;
    color: #1e3a5f;
  }

  .nav {
    display: flex;
    gap: 4rem;
  }

  .nav a {
    font-weight: 600;
    color: #4b5563;
    transition: color 0.2s;
    font-size: 23px;
  }

  .nav a:hover {
    color: orange;
  }

  .contact-phone {
    font-weight: 600;
    color: #1e3a5f;
  }

  .footer {
    background: #1e3a5f;
    color: #fff;
    margin-top: 4rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .footer-section h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .footer-section h4 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: #94a3b8;
  }

  .footer-section p,
  .footer-section a {
    color: #cbd5e1;
    line-height: 1.6;
  }

  .footer-section a:hover {
    color: #fff;
  }

  .footer-map-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.75rem;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s ease;
  }

  .footer-map-link:hover {
    transform: scale(1.02);
  }

  .footer-map-iframe {
    pointer-events: none;
  }

  .footer-map-link span {
    font-size: 0.8rem;
    color: #60a5fa;
  }

  .footer-map-link:hover span {
    color: #93c5fd;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.5rem 2rem;
    text-align: center;
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      gap: 1rem;
      padding: 0.75rem 1rem;
    }

    .nav {
      gap: 1.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav a {
      font-size: 16px;
    }

    .logo-text {
      font-size: 28px;
    }

    .logo-img {
      width: 70px;
    }
  }
</style>
